# ─────────────────────────────────────────────────────────────
# Carlos Council — environment configuration
# Copy this file to `.env` and fill in your values:
#   cp .env.example .env
# The backend reads these. NEVER commit your real .env (it is gitignored).
# ─────────────────────────────────────────────────────────────

# --- LLM provider (required) ---------------------------------
# Your API key. The backend uses the OpenAI SDK, so any
# OpenAI-compatible provider works (OpenAI, OpenRouter, Ollama, vLLM…).
# This key lives ONLY in the backend. It is never sent to the browser.
OPENAI_API_KEY=sk-your-key-here

# API base URL for your provider.
#   OpenAI:     https://api.openai.com/v1
#   OpenRouter: https://openrouter.ai/api/v1
#   Ollama:     http://localhost:11434/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Model used for all six agents.
#   OpenAI:     gpt-4o
#   OpenRouter: anthropic/claude-sonnet-4
#   Ollama:     llama3.1:70b
MODEL_NAME=gpt-4o

# Network timeout (seconds) and retry count for LLM API calls.
# Defaults shown; uncomment to override.
# LLM_TIMEOUT=120
# LLM_MAX_RETRIES=2

# --- Storage (optional) --------------------------------------
# Where the SQLite database file lives inside the backend container.
# Leave unset to use the default (backend/data/council.db).
# DB_PATH=/app/data/council.db

# --- CORS (optional) -----------------------------------------
# Comma-separated browser origins allowed to call the backend directly.
# In the default setup the Next.js frontend proxies requests server-side, so
# the browser never hits the backend and this can stay at the local defaults.
# Set this only if you expose the backend directly to browsers in a hosted
# deployment (e.g. https://your-app.example.com).
# ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Frontend (optional) -------------------------------------
# Public site origin, used to build absolute OpenGraph/Twitter image URLs for
# link previews. Set this in production (e.g. https://carloscouncil.app).
# Defaults to http://localhost:3000 for local development.
NEXT_PUBLIC_SITE_URL=

# Optional Spline 3D scene URL for the landing hero (Carlos).
# Leave empty to use the static hero. Must start with NEXT_PUBLIC_ to be
# readable by the browser — it is a public URL, not a secret.
NEXT_PUBLIC_SPLINE_SCENE_URL=
